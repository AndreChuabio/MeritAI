# Merit env template -- copy to .env and fill in.
# Minimum to run: AI_GATEWAY_API_KEY. Everything else is optional or is
# needed only for a specific surface (see the comments below).

# Merit calls three providers -- Google (repo ingest), Anthropic (drafting), and
# OpenAI (embeddings) -- so a single provider key cannot run the pipeline. One
# Vercel AI Gateway key routes to all three.
# Get one free at https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# OPTIONAL. Everything below in this block is an enhancement, not a
# requirement. Merit runs without any of it.
SENSO_API_KEY=          # optional: brand-kit tone retrieval for outreach drafts
NIMBLE_API_KEY=         # optional: contact discovery for outreach targets
DD_API_KEY=             # optional: Datadog LLM observability
ALLOW_DEV_AUTH=         # set to 1 ONLY for local development of the legacy Streamlit app

# Datadog cloud forward -- sub-config used only when DD_API_KEY above is set.
# DD_SITE: datadoghq.com (US1), datadoghq.eu (EU1), us3.datadoghq.com, etc.
DD_SITE=datadoghq.eu
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=paperpilot

# Senso sub-config -- used only when SENSO_API_KEY above is set.
# Get from: https://app.senso.ai -> API keys
SENSO_BASE_URL=https://apiv2.senso.ai/api/v1

# ClickHouse Cloud -- required only by the legacy Streamlit app (Productize/
# Market/Track pages), not by the FastAPI backend + web frontend.
# Get from: https://clickhouse.cloud after creating a service
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# GitHub PAT for repo ingest -- if unset, code falls back to `gh auth token`
GITHUB_TOKEN=

# Demo mode -- short-circuits live calls to cached fixtures
DEMO_MODE=false

# Model selection -- override defaults if needed
MODEL_INGEST=google/gemini-2.5-flash
MODEL_DRAFT=anthropic/claude-sonnet-4-6
MODEL_EMBED=openai/text-embedding-3-small

# Supabase (Postgres + pgvector + Auth) -- production data layer for the
# FastAPI backend + web frontend.
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
# SUPABASE_DB_URL uses the IPv4 session pooler (port 5432) for the FastAPI
# backend and migration scripts. On IPv6-only networks use the pooler host,
# not the direct db.<ref>.supabase.co host.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Merit auth shim -- JSON list of users for the passcode sign-in screen.
# If unset/empty/invalid, the app falls back to a dev account (user_id=dev,
# passcode=dev) and surfaces a visible warning. Replace passcodes before prod.
PAPERPILOT_USERS_JSON=[{"user_id":"user1","name":"Ada Lovelace","passcode":"replace-me"},{"user_id":"user2","name":"Alan Turing","passcode":"replace-me"}]

# PaperPilot env template -- copy to .env and fill in
# Run the app with:  DD_API_KEY=$DD_API_KEY lapdog streamlit run Productize.py

# Vercel AI Gateway -- multi-provider model routing
# Get from: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Datadog cloud forward (recommended for the sponsor pitch).
# Get DD_API_KEY from the LLM Observability setup wizard or
#   org settings -> API Keys.
# DD_SITE: datadoghq.com (US1), datadoghq.eu (EU1), us3.datadoghq.com, etc.
DD_API_KEY=
DD_SITE=datadoghq.eu
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=paperpilot

# ClickHouse Cloud
# Get from: https://clickhouse.cloud after creating a service
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# GitHub PAT for repo ingest -- if unset, code falls back to `gh auth token`
GITHUB_TOKEN=

# Demo mode -- short-circuits live calls to cached fixtures
DEMO_MODE=false

# Model selection -- override defaults if needed
MODEL_INGEST=google/gemini-2.5-flash
MODEL_DRAFT=anthropic/claude-sonnet-4-6
MODEL_EMBED=openai/text-embedding-3-small

# Senso (brand-kit / content-types / knowledge-base / content-generation)
# Get from: https://app.senso.ai -> API keys (workspace: Agentic-hack)
SENSO_API_KEY=
SENSO_BASE_URL=https://apiv2.senso.ai/api/v1

# Nimble (web scraping proxy for Google Scholar live fetch)
# Get from: https://app.nimbleway.com/dashboard
NIMBLE_API_KEY=

# Supabase (Postgres + pgvector + Auth) -- production data layer.
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
# SUPABASE_DB_URL uses the IPv4 session pooler (port 5432) for the FastAPI
# backend and migration scripts. On IPv6-only networks use the pooler host,
# not the direct db.<ref>.supabase.co host.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# PaperPilot auth shim -- JSON list of users for the passcode sign-in screen.
# If unset/empty/invalid, the app falls back to a dev account (user_id=dev,
# passcode=dev) and surfaces a visible warning. Replace passcodes before prod.
PAPERPILOT_USERS_JSON=[{"user_id":"andre","name":"Andre","passcode":"replace-me"},{"user_id":"nikki","name":"Nikki","passcode":"replace-me"}]
